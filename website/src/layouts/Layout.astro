---
import "../styles/global.css";
import Logo from "../components/Logo.astro";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = "Actuali",
  description = "A native iOS companion app for self-hosted Actual Budget.",
  noindex = false,
} = Astro.props;

const testflight = "https://testflight.apple.com/join/NsYntuXB";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <meta name="theme-color" content="#5a2a85" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/icon.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <title>{title}</title>
  </head>
  <body
    class="min-h-screen bg-neutral-50 text-neutral-900 antialiased selection:bg-violet-200 selection:text-violet-950"
  >
    <header
      class="sticky top-0 z-40 border-b border-neutral-200/70 bg-white/80 backdrop-blur-md"
    >
      <div
        class="mx-auto flex max-w-5xl items-center justify-between px-5 py-3 sm:px-6"
      >
        <a href="/" class="flex items-center" aria-label="Actuali home">
          <Logo size={28} />
        </a>
        <div class="flex items-center gap-1 sm:gap-2">
          <nav class="flex items-center text-sm font-medium text-neutral-600">
            <a
              href="/changelog"
              class="rounded-lg px-2.5 py-1.5 transition hover:bg-neutral-100 hover:text-neutral-900 sm:px-3"
              >Changelog</a
            >
            <a
              href="/support"
              class="rounded-lg px-2.5 py-1.5 transition hover:bg-neutral-100 hover:text-neutral-900 sm:px-3"
              >Support</a
            >
            <a
              href="/privacy"
              class="hidden rounded-lg px-3 py-1.5 transition hover:bg-neutral-100 hover:text-neutral-900 sm:inline-block"
              >Privacy</a
            >
          </nav>
          <a
            href={testflight}
            class="ml-1 hidden rounded-full bg-neutral-900 px-4 py-2 text-sm font-medium text-white shadow-sm transition hover:bg-neutral-700 sm:inline-block"
            >Get the app</a
          >
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-5 py-12 sm:px-6">
      <slot />
    </main>

    <footer class="mt-8 border-t border-neutral-200 bg-white">
      <div
        class="mx-auto flex max-w-5xl flex-col gap-6 px-5 py-10 sm:px-6 md:flex-row md:items-start md:justify-between"
      >
        <div class="max-w-sm space-y-3">
          <Logo size={26} />
          <p class="text-sm text-neutral-500">
            An independent, native iOS app for self-hosted
            <a
              href="https://actualbudget.org"
              class="underline decoration-neutral-300 underline-offset-2 hover:text-neutral-700"
              >Actual Budget</a
            >. Not affiliated with Actual Budget.
          </p>
        </div>
        <nav
          class="flex flex-wrap gap-x-6 gap-y-2 text-sm font-medium text-neutral-500"
        >
          <a href="/changelog" class="transition hover:text-neutral-900"
            >Changelog</a
          >
          <a href="/support" class="transition hover:text-neutral-900">Support</a>
          <a href="/privacy" class="transition hover:text-neutral-900">Privacy</a>
          <a href={testflight} class="transition hover:text-neutral-900"
            >TestFlight</a
          >
          <a
            href="https://github.com/MattFaz/actuali"
            class="transition hover:text-neutral-900">GitHub</a
          >
        </nav>
      </div>
    </footer>
  </body>
</html>
